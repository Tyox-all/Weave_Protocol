{
  "name": "@weave_protocol/tollere",
  "version": "0.2.2",
  "description": "Supply chain security for AI-generated code - scans packages, Docker images, and IDE extensions (VS Code, Cursor, JetBrains) before install for typosquats, CVEs, sandwich-pattern attacks, and Docker tag overwriting",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "weave-tollere": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "node --test tests/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "supply-chain",
    "security",
    "npm",
    "pypi",
    "typosquat",
    "cve",
    "ai-security",
    "ai-agents",
    "dependency-scanning",
    "weave-protocol",
    "mcp",
    "model-context-protocol",
    "claude",
    "agentic",
    "vibe-coding"
  ],
  "author": "Trent Yoxall",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tyox-all/Weave_Protocol.git",
    "directory": "tollere"
  },
  "homepage": "https://github.com/Tyox-all/Weave_Protocol/tree/main/tollere#readme",
  "bugs": {
    "url": "https://github.com/Tyox-all/Weave_Protocol/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
